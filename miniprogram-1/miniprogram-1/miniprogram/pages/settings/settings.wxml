<view class="settings-container">
  <view class="settings-header">
    <text class="header-title">报警阈值设置</text>
    <text class="header-desc">设置各参数的报警触发阈值</text>
  </view>

  <view class="settings-content">
    <!-- 温度阈值设置 -->
    <view class="setting-item">
      <view class="setting-label">
        <text class="label-text">温度报警阈值</text>
        <text class="label-desc">{{tempThreshold}}℃ 及以上触发预警</text>
      </view>
      
      <view class="setting-control">
        <slider 
          min="{{tempMin}}" 
          max="{{tempMax}}" 
          value="{{tempThreshold}}" 
          step="1"
          bindchange="onTempSliderChange"
          activeColor="#1677ff"
        />
        
        <view class="input-group">
          <input 
            type="number" 
            value="{{tempInput}}" 
            bindinput="onTempInput"
            placeholder="输入温度值"
            class="threshold-input"
          />
          <text class="unit">℃</text>
        </view>
        
        <view class="range-info">
          <text class="range-min">{{tempMin}}℃</text>
          <text class="range-max">{{tempMax}}℃</text>
        </view>
      </view>
    </view>

    <!-- 烟雾阈值设置 -->
    <view class="setting-item">
      <view class="setting-label">
        <text class="label-text">烟雾浓度报警阈值</text>
        <text class="label-desc">{{smokeThreshold}}ppm 及以上触发预警</text>
      </view>
      
      <view class="setting-control">
        <slider 
          min="{{smokeMin}}" 
          max="{{smokeMax}}" 
          value="{{smokeThreshold}}" 
          step="10"
          bindchange="onSmokeSliderChange"
          activeColor="#1677ff"
        />
        
        <view class="input-group">
          <input 
            type="number" 
            value="{{smokeInput}}" 
            bindinput="onSmokeInput"
            placeholder="输入烟雾浓度值"
            class="threshold-input"
          />
          <text class="unit">ppm</text>
        </view>
        
        <view class="range-info">
          <text class="range-min">{{smokeMin}}ppm</text>
          <text class="range-max">{{smokeMax}}ppm</text>
        </view>
      </view>
    </view>

    <!-- 固定阈值说明 -->
    <view class="fixed-thresholds">
      <text class="fixed-title">固定阈值说明</text>
      <view class="fixed-item">
        <text class="fixed-label">声音报警阈值：</text>
        <text class="fixed-value">70dB 及以上触发预警</text>
      </view>
      <view class="fixed-item">
        <text class="fixed-label">火焰报警阈值：</text>
        <text class="fixed-value">检测到火焰即触发预警</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="settings-actions">
    <button 
      class="reset-button" 
      bindtap="resetToDefault"
    >
      重置为默认值
    </button>
    <button 
      class="save-button" 
      bindtap="saveSettings"
    >
      保存设置
    </button>
  </view>
</view>
    