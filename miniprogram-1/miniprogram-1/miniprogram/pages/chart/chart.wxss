.chart-container {
  padding: 16px;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* 页面头部与筛选器 */
.page-header {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.filter-group {
  display: flex;
  gap: 10px;
}

.filter-btn {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 14px;
  background-color: white;
  color: #666;
  border: 1px solid #eee;
}

.filter-btn.active {
  background-color: #1677ff;
  color: white;
  border-color: #1677ff;
}

.refresh-btn {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 14px;
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1px solid #1890ff;
}

/* 图表网格布局 */
.chart-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.chart-item {
  background-color: white;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.chart-title {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
  display: block;
}

.chart-wrapper {
  width: 100%;
  height: 250px; /* 固定图表高度 */
}

/* 无数据提示 */
.no-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  gap: 16px;
}

.no-data-text {
  font-size: 16px;
  color: #999;
}

/* 返回按钮 */
.back-btn {
  width: 100%;
  padding: 12px 0;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  background-color: #1677ff;
  color: white;
  margin-top: 20px;
}