<view class="container">
  <!-- 设备状态头部 -->
  <view class="device-header">
    <view class="device-info">
      <text class="device-name">{{deviceName}}</text>
      <view class="online-status">
        <view class="status-indicator {{isOnline ? 'online' : 'offline'}}"></view>
        <text class="status-text">{{deviceStatusText}}</text>
      </view>
    </view>
    <view class="overall-status {{overallStatus}}">
      <text>{{overallStatus === 'normal' ? '正常' : overallStatus === 'warning' ? '预警' : '火警'}}</text>
    </view>
  </view>

  <!-- 传感器数据卡片 -->
  <view class="sensor-grid">
    <!-- 温度卡片 -->
    <view class="sensor-card {{tempStatus}}">
      <view class="sensor-icon">🌡️</view>
      <view class="sensor-info">
        <text class="sensor-name">温度</text>
        <text class="sensor-value">{{temperature}}℃</text>
        <text class="sensor-status" wx:if="{{!isOnline}}">离线</text>
      </view>
      <view class="sensor-threshold">
        <text>{{temperature > 40 ? '🔥 过高' : temperature > 35 ? '⚡ 偏高' : '✅ 正常'}}</text>
      </view>
    </view>

    <!-- 湿度卡片 -->
    <view class="sensor-card normal">
      <view class="sensor-icon">💧</view>
      <view class="sensor-info">
        <text class="sensor-name">湿度</text>
        <text class="sensor-value">{{humidity}}%</text>
        <text class="sensor-status" wx:if="{{!isOnline}}">离线</text>
      </view>
      <view class="sensor-threshold">
        <text>正常范围: 20-80%</text>
      </view>
    </view>

    <!-- 烟雾浓度卡片 -->
    <view class="sensor-card {{smokeStatus}}">
      <view class="sensor-icon">🔬</view>
      <view class="sensor-info">
        <text class="sensor-name">烟雾浓度</text>
        <text class="sensor-value">{{smoke}}</text>
        <text class="sensor-status" wx:if="{{!isOnline}}">离线</text>
      </view>
      <view class="sensor-threshold">
        <text>{{smoke < 1000 ? '⚠️ 报警' : smoke < 1300 ? '⚡ 预警' : '✅ 正常'}}</text>
      </view>
    </view>

  
    <!-- 火焰卡片 -->
    <view class="sensor-card {{flame ? 'alarm' : 'normal'}}">
      <view class="sensor-icon">🔥</view>
      <view class="sensor-info">
        <text class="sensor-name">火焰</text>
        <text class="sensor-value">{{flame ? '检测到火焰!' : '安全'}}</text>
        <text class="sensor-status" wx:if="{{!isOnline}}">离线</text>
      </view>
      <view class="sensor-threshold">
        <text>{{flame ? '⚠️ 危险' : '✅ 正常'}}</text>
      </view>
    </view>

    <!-- 光照卡片 -->
    <view class="sensor-card {{lightStatus}}" bindtap="goToLight">
      <view class="sensor-icon">💡</view>
      <view class="sensor-info">
        <text class="sensor-name">光照</text>
        <text class="sensor-value">{{light}}lux</text>
        <text class="sensor-status" wx:if="{{!isOnline}}">离线</text>
      </view>
      <view class="sensor-threshold">
        <text>{{light > 130 ? '⚠️ 过强' : light > 120 ? '⚡ 偏强' : '✅ 正常'}}</text>
      </view>
    </view>
  </view>

  <!-- 设备控制区域 -->
  <view class="control-section">
    <text class="section-title">设备控制</text>
    <view class="control-grid">
      <!-- 舵机控制 -->
      <view class="control-card">
        <text class="control-name">舵机</text>
        <view class="control-icon {{servo ? 'active' : ''}}">⚙️</view>
        <button
          class="control-button {{servo ? 'on' : 'off'}}"
          bindtap="controlServo"
          data-device="servo"
          disabled="{{servoRunning}}"
        >
          {{servo ? '关闭' : '打开'}}
        </button>
        <text class="control-hint {{servo ? 'active-hint' : ''}}">
          {{servo ? '舵机已开启' : '点击控制舵机'}}
        </text>
      </view>

      <!-- 门窗控制 -->
      <view class="control-card">
        <text class="control-name">门窗</text>
        <view class="control-icon {{doorWindow ? 'active' : ''}}">🚪</view>
        <button 
          class="control-button {{doorWindow ? 'on' : 'off'}}"
          bindtap="manualControlDevice"
          data-device="doorWindow"
          disabled="{{doorWindowAutoClosing}}"
        >
          {{doorWindow ? '关闭' : '打开'}}
        </button>
        <text class="control-hint {{doorWindow ? 'active-hint' : ''}}">
          {{doorWindow ? ('自动关闭倒计时: ' + doorWindowCountdown + 's') : '自动开启10秒后关闭'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 功能按钮区域 -->
  <view class="action-buttons">
    <button 
      class="alarm-button" 
      bindtap="goToAlarmDetails"
    >
      报警记录
      <view class="unhandled-badge" wx:if="{{unhandledCount > 0}}">
        {{unhandledCount}}
      </view>
    </button>
    <button 
      class="history-button"
      bindtap="goToHistory"
    >
      历史数据
    </button>
    <button 
      class="settings-button" 
      bindtap="goToSettings"
    >
      阈值设置
    </button>
    <button 
      class="slave-data-button" 
      bindtap="goToSlaveData"
    >
      从机数据
    </button>
  </view>
</view>
