.container {
  padding: 10rpx 0;
  background: linear-gradient(180deg, #f0f4ff 0%, #e6f7ff 100%);
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 智能分析横幅 */
.intelligence-banner {
  position: relative;
  margin: 10rpx 20rpx 20rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.banner-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  opacity: 0.9;
}

.banner-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
}

.banner-icon {
  margin-right: 20rpx;
}

.icon-robot {
  font-size: 48rpx;
  animation: pulse 2s infinite;
}

.banner-text {
  flex: 1;
}

.banner-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 5rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.banner-refresh {
  padding: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.banner-refresh:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.refresh-icon {
  font-size: 28rpx;
  color: white;
}

.wave-animation {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  animation: wave 3s linear infinite;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 20rpx 15rpx 20rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-dot.online {
  background: #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.6);
}

.status-text, .last-update {
  font-size: 22rpx;
  color: #666;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes wave {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 0 20rpx 15rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.12);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 20rpx;
}

.health-icon {
  background: linear-gradient(135deg, #52c41a, #73d13d);
}

.safety-icon {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
}

.statistics-icon {
  background: linear-gradient(135deg, #722ed1, #9254de);
}

.ai-icon {
  background: linear-gradient(135deg, #fa8c16, #ffa940);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.loading-text {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: normal;
}

/* 系统统计概览 */
.system-stats .stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  width: 100%;
}

.stat-item {
  text-align: center;
  padding: 16rpx 8rpx;
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 12rpx;
  border: 1rpx solid rgba(24, 144, 255, 0.1);
  transition: all 0.3s ease;
}

.stat-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
}

.stat-icon {
  font-size: 24rpx;
  margin-bottom: 6rpx;
  display: block;
}

.stat-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 6rpx;
  line-height: 1.2;
}

.stat-value.analysis-period {
  font-size: 18rpx;
  color: #666;
  font-weight: normal;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
  line-height: 1.2;
}

/* 卡片并排布局 */
.cards-row {
  display: flex;
  gap: 12rpx;
  margin: 0 20rpx 15rpx 20rpx;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.cards-row .card {
  flex: 1;
  margin: 0;
  width: auto; /* 让flex控制宽度 */
}

/* 设备健康度评估 */
.health-card {
  border-left: 4rpx solid #52c41a;
  background: linear-gradient(135deg, #f6ffed, #ffffff);
}

.health-content {
  margin-top: 10rpx;
}

.health-score-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.score-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f6ffed, #ffffff);
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
}

.score-value {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

.score-unit {
  font-size: 18rpx;
  color: #666;
  margin-top: 2rpx;
}

.health-info {
  flex: 1;
}

.health-status {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-icon {
  font-size: 20rpx;
}

.health-factors {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.factor-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
}

.factor-progress {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: #f0f0f0;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.factor-name {
  color: #666;
  font-size: 20rpx;
}

.factor-value {
  color: #333;
  font-weight: 600;
  font-size: 22rpx;
  min-width: 80rpx;
  text-align: right;
}

/* 环境安全指数 */
.safety-card {
  border-left: 4rpx solid #1890ff;
  background: linear-gradient(135deg, #e6f7ff, #ffffff);
}

.safety-content {
  margin-top: 10rpx;
}

.safety-score-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.safety-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #e8e8e8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.15);
}

.safety-value {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

.safety-unit {
  font-size: 18rpx;
  color: #666;
  margin-top: 2rpx;
}

.safety-info {
  flex: 1;
}

.safety-level {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.safety-badge {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.safety-factors {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.safety-factor {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
}

.factor-icon {
  font-size: 20rpx;
}

.factor-details {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.safety-factor-name {
  color: #666;
  font-size: 20rpx;
}

.safety-factor-value {
  color: #333;
  font-weight: 600;
  font-size: 22rpx;
}

/* 传感器数据统计 */
.statistics-card {
  border-left: 4rpx solid #722ed1;
  background: linear-gradient(135deg, #f9f0ff, #ffffff);
}

.sensor-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sensor-row {
  display: flex;
  gap: 12rpx;
}

.sensor-item {
  flex: 1;
  padding: 16rpx;
  background: linear-gradient(135deg, #f9f0ff, #faf5ff);
  border-radius: 12rpx;
  border: 1rpx solid rgba(114, 46, 209, 0.2);
  transition: all 0.3s ease;
}

.sensor-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #efdbff, #f9f0ff);
}

.sensor-header {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.sensor-icon {
  font-size: 18rpx;
}

.sensor-name {
  font-size: 22rpx;
  color: #722ed1;
  font-weight: 600;
}

.sensor-data {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 6rpx;
}

.sensor-avg {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.sensor-range {
  font-size: 18rpx;
  color: #666;
}

.sensor-trend {
  font-size: 20rpx;
  font-weight: bold;
  text-align: center;
}

.trend-icon {
  font-size: 18rpx;
}

.sensor-trend.up {
  color: #ff4d4f;
}

.sensor-trend.down {
  color: #52c41a;
}

.sensor-trend.stable {
  color: #666;
}

/* AI智能建议 */
.ai-suggestions-card {
  border-left: 4rpx solid #fa8c16;
  background: linear-gradient(135deg, #fff7e6, #ffffff);
}

.ai-suggestions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.no-suggestions {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

.no-data-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
  opacity: 0.6;
}

.no-data-text {
  font-size: 22rpx;
  color: #999;
}

.suggestion-item {
  padding: 16rpx;
  border-radius: 12rpx;
  border-left: 3rpx solid #d9d9d9;
  background: linear-gradient(135deg, #fafafa, #ffffff);
  transition: all 0.3s ease;
}

.suggestion-item:active {
  transform: scale(0.98);
}

.suggestion-item.high {
  border-left-color: #ff4d4f;
  background: linear-gradient(135deg, #fff2f0, #ffffff);
}

.suggestion-item.medium {
  border-left-color: #faad14;
  background: linear-gradient(135deg, #fffbe6, #ffffff);
}

.suggestion-item.low {
  border-left-color: #52c41a;
  background: linear-gradient(135deg, #f6ffed, #ffffff);
}

.suggestion-header {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.suggestion-icon {
  margin-top: 2rpx;
}

.priority-icon {
  font-size: 20rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.suggestion-description {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.suggestion-meta {
  margin-top: 8rpx;
}

.meta-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-tag {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #666;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.meta-tag.category {
  background: rgba(24, 144, 255, 0.1);
  color: #1890ff;
  border-color: rgba(24, 144, 255, 0.2);
}

.meta-tag.time {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
  border-color: rgba(82, 196, 26, 0.2);
}

.meta-tag.cost {
  background: rgba(250, 140, 22, 0.1);
  color: #fa8c16;
  border-color: rgba(250, 140, 22, 0.2);
}

.suggestion-action {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.action-label {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
  white-space: nowrap;
}

.action-text {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

/* 错误处理 */
.error-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff2f0;
  border-radius: 8rpx;
  border: 1rpx solid #ffccc7;
}

.error-text {
  font-size: 26rpx;
  color: #ff4d4f;
  flex: 1;
}

.retry-btn {
  margin-left: 20rpx;
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 4rpx;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

/* 页面底部 */
.footer {
  margin-top: 40rpx;
  padding: 20rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  text-align: center;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.note {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .sensor-row {
    flex-direction: column;
  }

  .health-score-container,
  .safety-score-container {
    flex-direction: column;
    text-align: center;
  }

  .cards-row {
    flex-direction: column;
    gap: 12rpx;
  }

  .cards-row .card {
    margin-bottom: 0;
    width: 100%; /* 小屏幕上保持全宽 */
  }

  /* 小屏幕上减少边距以充分利用空间 */
  .intelligence-banner,
  .status-bar,
  .card,
  .footer {
    margin-left: 10rpx;
    margin-right: 10rpx;
    width: calc(100% - 20rpx);
  }

  .cards-row {
    margin-left: 10rpx;
    margin-right: 10rpx;
    width: calc(100% - 20rpx);
  }
}

/* 加载动画 */
@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.loading-text {
  animation: pulse 1.5s ease-in-out infinite;
}

/* 设备选择器 */
.device-selector {
  background: white;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin: 0 20rpx 15rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selector-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.selector-icon {
  font-size: 28rpx;
}

.device-picker {
  flex: 1;
  margin-left: 20rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 8rpx;
  border: 1rpx solid rgba(24, 144, 255, 0.2);
}

.picker-text {
  font-size: 24rpx;
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 分布条形图（汇总模式） */
.health-distribution,
.safety-distribution {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 10rpx;
}

.distribution-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
}

.dist-label {
  min-width: 80rpx;
  color: #666;
}

.dist-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.dist-fill.excellent {
  background: linear-gradient(90deg, #52c41a, #73d13d);
}

.dist-fill.good {
  background: linear-gradient(90deg, #1890ff, #40a9ff);
}

.dist-fill.moderate {
  background: linear-gradient(90deg, #faad14, #fa8c16);
}

.dist-value {
  min-width: 50rpx;
  text-align: right;
  font-weight: 600;
  color: #333;
}

/* 趋势图表卡片 */
.trends-card {
  border-left: 4rpx solid #13c2c2;
  background: linear-gradient(135deg, #e6fffb, #ffffff);
}

.trends-icon {
  background: linear-gradient(135deg, #13c2c2, #36cfc9);
}

.trends-chart-container {
  width: 100%;
  height: 300rpx;
  margin-top: 10rpx;
}

ec-canvas {
  width: 100%;
  height: 100%;
}